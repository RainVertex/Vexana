// The Workspace module is a single pane of glass over an integrated task
// manager (Plane). These tables are a lossless mirror of Plane's resources,
// kept fresh by the sync engine (full pull + incremental + webhook). Mirror
// rows hold a `raw` Json column carrying the full upstream payload so that
// schema drift in Plane doesn't break reads. Mutations in the platform UI go
// through Plane's REST API (write-through proxy) and the response is upserted
// here in the same request — so the mirror is always at-least-as-fresh as
// Plane after a write.
//
// `externalId` is Plane's UUID; we never reuse it as our PK so collisions
// between Plane instances are impossible. `(integrationId, externalId)` is
// the global identity, scoped one level up in child models via project FK.

model PlaneWorkspace {
  id            String         @id @default(cuid())
  integrationId String
  externalId    String // Plane workspace.id (UUID)
  slug          String // used in API paths: /workspaces/<slug>/...
  name          String
  logoUrl       String?
  lastSyncedAt  DateTime?
  raw           Json
  integration   Integration    @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  projects      PlaneProject[]
  members       PlaneMember[]

  @@unique([integrationId, externalId])
  @@index([slug])
}

model PlaneProject {
  id            String          @id @default(cuid())
  integrationId String
  workspaceId   String
  externalId    String
  identifier    String // Plane "PROJ" prefix used in issue keys
  name          String
  description   String?
  emoji         String?
  archivedAt    DateTime?
  lastSyncedAt  DateTime?
  raw           Json
  workspace     PlaneWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workItems     PlaneWorkItem[]
  states        PlaneState[]
  labels        PlaneLabel[]
  cycles        PlaneCycle[]
  modules       PlaneModule[]

  @@unique([integrationId, externalId])
  @@index([workspaceId, archivedAt])
}

model PlaneState {
  id         String          @id @default(cuid())
  projectId  String
  externalId String
  name       String
  color      String?
  // Plane state group: backlog | unstarted | started | completed | cancelled.
  // Open string (not enum) to absorb upstream additions without migration.
  group      String
  order      Float
  isDefault  Boolean         @default(false)
  project    PlaneProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workItems  PlaneWorkItem[]

  @@unique([projectId, externalId])
  @@index([projectId, order])
}

model PlaneLabel {
  id         String       @id @default(cuid())
  projectId  String
  externalId String
  name       String
  color      String?
  project    PlaneProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
}

model PlaneCycle {
  id         String       @id @default(cuid())
  projectId  String
  externalId String
  name       String
  startDate  DateTime?
  endDate    DateTime?
  raw        Json
  project    PlaneProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
}

model PlaneModule {
  id         String       @id @default(cuid())
  projectId  String
  externalId String
  name       String
  status     String?
  raw        Json
  project    PlaneProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, externalId])
}

model PlaneWorkItem {
  id                String          @id @default(cuid())
  projectId         String
  externalId        String // Plane work_item.id
  sequenceId        Int // PROJ-123 -> 123
  name              String
  description       String? // markdown body
  stateId           String?
  // Plane priority enum: none | low | medium | high | urgent. Open-string to
  // absorb upstream additions; UI normalizes via a small dictionary.
  priority          String
  // Denormalized for fast `my-work` queries. Known limitation: no FK
  // enforcement — if a PlaneMember is deleted out-of-band, stale IDs stay
  // until the next sync of this work item refreshes the array. Mirror is
  // eventually-consistent with Plane; we accept this for query speed.
  assigneeIds       String[]        @default([])
  labelIds          String[]        @default([])
  parentId          String?
  cycleId           String?
  moduleId          String?
  startDate         DateTime?
  targetDate        DateTime?
  // Set when state.group transitions to "completed", cleared on revert.
  // Powers cycle-time and throughput metrics in Phase D.
  completedAt       DateTime?
  externalCreatedAt DateTime
  externalUpdatedAt DateTime
  lastSyncedAt      DateTime
  raw               Json
  project           PlaneProject    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  state             PlaneState?     @relation(fields: [stateId], references: [id], onDelete: SetNull)
  parent            PlaneWorkItem?  @relation("PlaneSubItems", fields: [parentId], references: [id], onDelete: SetNull)
  subItems          PlaneWorkItem[] @relation("PlaneSubItems")
  comments          PlaneComment[]

  @@unique([projectId, externalId])
  @@index([projectId, stateId])
  @@index([projectId, completedAt])
  @@index([projectId, externalUpdatedAt])
}

model PlaneComment {
  id                String        @id @default(cuid())
  workItemId        String
  externalId        String
  authorExternalId  String? // PlaneMember.externalId; not FK because Plane may return a deleted author
  body              String
  externalCreatedAt DateTime
  externalUpdatedAt DateTime
  raw               Json
  workItem          PlaneWorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@unique([workItemId, externalId])
  @@index([workItemId, externalCreatedAt])
}

model PlaneMember {
  id          String             @id @default(cuid())
  workspaceId String
  externalId  String // Plane user.id
  email       String
  displayName String
  avatarUrl   String?
  workspace   PlaneWorkspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mappings    PlaneUserMapping[]

  @@unique([workspaceId, externalId])
  @@index([email])
}

// Maps a platform User to a Plane workspace member. Auto-created on email
// match during sync; manually editable via /workspace/integrations/plane/:id.
// One platform user can map to multiple Plane members (one per workspace).
model PlaneUserMapping {
  id             String      @id @default(cuid())
  platformUserId String
  planeMemberId  String
  createdAt      DateTime    @default(now())
  user           User        @relation(fields: [platformUserId], references: [id], onDelete: Cascade)
  member         PlaneMember @relation(fields: [planeMemberId], references: [id], onDelete: Cascade)

  @@unique([platformUserId, planeMemberId])
  @@index([planeMemberId])
}

// One per Integration. Sync cursors live here to keep the Integration row
// small (it's read on every authenticated request that touches workspace).
model PlaneSyncCursor {
  id             String      @id @default(cuid())
  integrationId  String      @unique
  lastFullSyncAt DateTime?
  lastWebhookAt  DateTime?
  // Reserved for future per-resource cursors when Plane exposes them.
  cursors        Json?
  integration    Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
}

model PlaneOAuthToken {
  id                String      @id @default(cuid())
  userId            String
  integrationId     String
  encryptedAccessToken  String
  encryptedRefreshToken String
  planeUserId       String
  planeEmail        String
  expiresAt         DateTime
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  integration       Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([userId, integrationId])
  @@index([integrationId])
}
