enum UserRole {
  admin
  member
}

enum UserTaskStatus {
  pending
  completed
  dismissed
}

// Class-table-inheritance marker. A 'human' row is a real person logged in
// via SSO. An 'agent' row is a synthetic identity created when an Agent is
// configured; every Agent has exactly one backing User with userKind='agent'.
// Auth, role checks, team membership, audit, and grants treat both kinds
// uniformly — the agent runs through the same middleware a human does.
enum UserKind {
  human
  agent
}

model User {
  id                              String                  @id @default(cuid())
  githubId                        String                  @unique
  githubLogin                     String                  @unique
  email                           String                  @unique
  displayName                     String
  avatarUrl                       String?
  role                            UserRole                @default(member)
  userKind                        UserKind                @default(human)
  status                          String                  @default("active")
  lastLoginAt                     DateTime?
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  sessions                        Session[]
  memberships                     TeamMembership[]
  auditEvents                     AuditEvent[]
  scaffoldPlans                   ScaffoldPlan[]
  scaffoldTasks                   ScaffoldTask[]
  scaffoldBindings                ScaffoldBinding[]
  scaffolderMcpTokens             ScaffolderMcpToken[]
  devDocComments                  DocComment[]
  devDocStaleReports              DocStaleReport[]
  starredEntities                 StarredEntity[]
  notifications                   Notification[]
  webhookSubscriptions            WebhookSubscription[]
  teamRequestsSubmitted           TeamRequest[]           @relation("TeamRequestRequester")
  teamRequestsReviewed            TeamRequest[]           @relation("TeamRequestReviewer")
  pages                           Page[]
  onboardingTasks                 UserTask[]
  departmentMemberships           DepartmentMembership[]
  templateAccessRequestsSubmitted TemplateAccessRequest[] @relation("TemplateAccessRequestRequester")
  templateAccessRequestsReviewed  TemplateAccessRequest[] @relation("TemplateAccessRequestReviewer")
  maintainerRequestsSubmitted     MaintainerRequest[]     @relation("MaintainerRequestRequester")
  maintainerRequestsReviewed      MaintainerRequest[]     @relation("MaintainerRequestReviewer")
  chatConversations               ChatConversation[]
  systemSettingsUpdated           SystemSetting[]         @relation("SystemSettingUpdatedBy")
  providerCredentialsUpdated      ProviderCredential[]    @relation("ProviderCredentialUpdatedBy")
  orgMemberships                  UserOrgMembership[]
  createdProjects                 Project[]               @relation("ProjectCreator")
  projectMemberships              ProjectMember[]         @relation("ProjectMemberUser")
  projectMembershipsAdded         ProjectMember[]         @relation("ProjectMemberAddedBy")
  createdTasks                    Task[]                  @relation("TaskCreator")
  taskAssignments                 TaskAssignee[]          @relation("TaskAssigneeUser")
  taskAssignmentsAdded            TaskAssignee[]          @relation("TaskAssigneeAddedBy")
  taskComments                    TaskComment[]           @relation("TaskCommentAuthor")

  @@index([userKind])
}

// Persistent record of which GitHub org logins the user was an active member
// of at last sign-in. Written by the auth callback for non-admin users; used
// by the integration disconnect flow to identify users that must be disabled
// when their only org is removed.
model UserOrgMembership {
  userId         String
  accountLogin   String
  lastVerifiedAt DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, accountLogin])
  @@index([accountLogin])
}

model UserTask {
  id          String         @id @default(cuid())
  userId      String
  kind        String
  status      UserTaskStatus @default(pending)
  payload     Json?
  createdAt   DateTime       @default(now())
  completedAt DateTime?
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Each kind is seeded at most once per user. The unique key prevents
  // duplicate rows if seeding races (e.g. two parallel `GET /tasks`).
  @@unique([userId, kind])
  @@index([userId, status])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditEvent {
  id          String   @id @default(cuid())
  actorUserId String?
  actorIp     String?
  kind        String
  targetKind  String?
  targetId    String?
  requestId   String?
  payload     Json
  createdAt   DateTime @default(now())
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([kind])
  @@index([actorUserId])
  @@index([targetKind, targetId])
}
