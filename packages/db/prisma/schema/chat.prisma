// Conversation history and write-action previews for the Platform Assistant
// chatbot. Conversations belong to a User and reference an Agent (the seeded
// "Platform Assistant"). Messages persist the full transcript including tool
// calls. ChatActionPreview holds the validated, awaiting-confirmation payload
// for two-phase write tools (prepare → submit). Submitting consumes a preview
// idempotently; superseded/expired previews fail cleanly.

model ChatConversation {
  id        String              @id @default(cuid())
  userId    String
  agentId   String
  title     String
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  agent     Agent               @relation(fields: [agentId], references: [id], onDelete: Restrict)
  messages  ChatMessage[]
  previews  ChatActionPreview[]

  @@index([userId, updatedAt])
  @@index([agentId])
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           String
  content        String
  toolCalls      Json?
  agentRunId     String?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model ChatActionPreview {
  id             String           @id @default(cuid())
  shortHandle    String
  conversationId String
  userId         String
  toolId         String
  parsedParams   Json
  serverSummary  String
  policyChecks   Json
  sideEffects    Json
  expiresAt      DateTime
  consumedAt     DateTime?
  supersededAt   DateTime?
  resultRefId    String?
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, shortHandle])
  @@index([conversationId, toolId, supersededAt, consumedAt])
  @@index([userId])
}
