enum IntegrationKind {
  github
  jira
  slack
  grafana
  plane
}

model Integration {
  id              String           @id @default(cuid())
  name            String
  description     String?
  kind            IntegrationKind
  enabled         Boolean          @default(true)
  // Tool-specific JSON. For kind=plane: { baseUrl, apiToken (encrypted via
  // packages/db/src/secrets), workspaceSlug, webhookSecret (encrypted) }.
  config          Json
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  planeWorkspaces PlaneWorkspace[]
  planeSyncCursor PlaneSyncCursor?
  // Team requests asking to mirror their team to this GitHub installation
  // when approved. Approve flow looks up accountLogin from `config`.
  teamRequests    TeamRequest[]
  // Grafana per-entity wiring + alert dedup state. Cascade-delete via FK so
  // disconnecting a Grafana integration drops these alongside.
  observabilityConfigs EntityObservabilityConfig[]
  alertDeliveryStates  AlertDeliveryState[]

  @@index([kind])
}

// Audit + telemetry for GitHub team/member reconciliation runs. Written by
// every layer (webhook, manual /resync, weekly cron). Source identifies
// which layer triggered the run; the delta counters power the drift dashboard.
model GithubReconciliationRun {
  id              String    @id @default(cuid())
  source          String
  installationId  Int
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  teamsCreated    Int       @default(0)
  teamsUpdated    Int       @default(0)
  teamsDeleted    Int       @default(0)
  membersAdded    Int       @default(0)
  membersRemoved  Int       @default(0)
  pendingQueued   Int       @default(0)
  pendingResolved Int       @default(0)
  orgMembershipsAdded   Int @default(0)
  orgMembershipsRemoved Int @default(0)
  errors          Json?

  @@index([installationId, startedAt])
}
