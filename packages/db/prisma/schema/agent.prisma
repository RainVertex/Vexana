enum AgentStatus {
  idle
  running
  succeeded
  failed
}

// Configured upstream the platform can reach (Ollama, OpenAI, Anthropic via
// its OpenAI-compatible endpoint, vLLM, etc.). Every provider is talked to
// via the OpenAI SDK; only baseUrl + the optional env-var-referenced API key
// differ. Secrets stay in env, not the database.
model LlmProvider {
  id           String     @id @default(cuid())
  slug         String     @unique
  displayName  String
  baseUrl      String
  apiKeyEnvVar String?
  kind         String
  enabled      Boolean    @default(true)
  models       LlmModel[]
  credential   ProviderCredential?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// Admin-entered provider API key, encrypted at rest (AES-256-GCM with the
// APP_SECRET_MASTER_KEY env key). One row per provider. resolveProviderApiKey
// prefers this over the provider's apiKeyEnvVar. The plaintext key is never
// returned to clients; only its presence (hasStoredKey) is exposed.
model ProviderCredential {
  id              String      @id @default(cuid())
  providerId      String      @unique
  encryptedValue  Bytes
  updatedAt       DateTime    @updatedAt
  updatedByUserId String?
  provider        LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  updatedBy       User?       @relation("ProviderCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

// A registered model an Agent can be pointed at. `modelName` is the wire
// identifier sent to the upstream API (e.g. "qwen3:8b",
// "claude-sonnet-4-6"). costPer1k* is null for self-hosted models.
model LlmModel {
  id             String      @id @default(cuid())
  slug           String      @unique
  displayName    String
  providerId     String
  modelName      String
  contextWindow  Int
  supportsTools  Boolean     @default(true)
  supportsVision Boolean     @default(false)
  costPer1kIn    Decimal?    @db.Decimal(10, 6)
  costPer1kOut   Decimal?    @db.Decimal(10, 6)
  enabled        Boolean     @default(true)
  provider       LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  agents         Agent[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([providerId])
}

// A task-specific agent configured through the UI. Lean by design: an agent
// is its model + system prompt + tool set + a simple approval mode. Agents
// act on behalf of the invoking user (per-user isolation flows through
// ToolContext.userId in the executor); they have no standalone identity,
// team ownership, or encrypted secret of their own.
model Agent {
  id           String      @id @default(cuid())
  name         String
  description  String?
  // Task category. Documented values: "platform-assistant" |
  // "catalog-enrichment" | "custom". Drives the recommended-model map in
  // @internal/llm-core (recommendationsForKind).
  kind         String
  status       AgentStatus @default(idle)
  modelId      String
  instructions String
  toolIds      Json        @default("[]")
  // "auto": write tools run without confirmation (autonomous agents like the
  // Catalog Enricher). "ask": write tools require confirmation; in chat this
  // is the prepare/submit prose flow, in autonomous runs write tools are
  // blocked.
  approvalMode String      @default("ask")
  maxToolCalls Int         @default(10)
  tokenBudget  Int?
  // Sampling temperature override. Null means use the per-model recommended
  // default (samplingDefaults in the openai_compat adapter, 0.2 elsewhere).
  temperature  Float?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  runs              AgentRun[]
  llmModel          LlmModel           @relation(fields: [modelId], references: [id])
  chatConversations ChatConversation[]

  @@index([modelId])
}

model AgentRun {
  id             String      @id @default(cuid())
  agentId        String
  status         AgentStatus
  input          Json
  output         Json?
  error          String?
  tokensInput    Int?
  tokensOutput   Int?
  costUsd        Decimal?    @db.Decimal(10, 6)
  containsWrites Boolean     @default(false)
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  agent          Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([status])
}
