enum AgentStatus {
  idle
  running
  succeeded
  failed
  cancelled
}

enum AgentApprovalMode {
  ask
  auto
}

// Configured upstream the platform can reach (Ollama, OpenAI, Anthropic via
// its OpenAI-compatible endpoint, vLLM, etc.). Every provider is talked to
// via the OpenAI SDK.
model LlmProvider {
  id           String              @id @default(cuid())
  slug         String              @unique
  displayName  String
  baseUrl      String
  apiKeyEnvVar String?
  kind         String
  enabled      Boolean             @default(true)
  models       LlmModel[]
  credential   ProviderCredential?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

// Admin-entered provider API key, encrypted at rest (AES-256-GCM with the
// APP_SECRET_MASTER_KEY env key). One row per provider. resolveProviderApiKey
// prefers this over the provider's apiKeyEnvVar. The plaintext key is never
// returned to clients, only its presence (hasStoredKey) is exposed.
model ProviderCredential {
  id              String      @id @default(cuid())
  providerId      String      @unique
  encryptedValue  Bytes
  updatedAt       DateTime    @updatedAt
  updatedByUserId String?
  provider        LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  updatedBy       User?       @relation("ProviderCredentialUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)
}

// A registered model an Agent can be pointed at. `modelName` is the wire
// identifier sent to the upstream API (e.g. "qwen3:8b",
// "claude-sonnet-4-6"). costPer1k* is null for self-hosted models.
// openrouterId is the canonical OpenRouter slug used to refresh costPer1k*
// from its public pricing list; null means the model is not price-synced.
model LlmModel {
  id                String      @id @default(cuid())
  slug              String      @unique
  displayName       String
  providerId        String
  modelName         String
  openrouterId      String?
  contextWindow     Int
  supportsTools     Boolean     @default(true)
  supportsVision    Boolean     @default(false)
  supportsReasoning Boolean     @default(false)
  costPer1kIn       Decimal?    @db.Decimal(10, 6)
  costPer1kOut      Decimal?    @db.Decimal(10, 6)
  enabled           Boolean     @default(true)
  provider          LlmProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  agents            Agent[]
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([providerId])
}

// A task-specific agent configured through the UI. Lean by design: an agent
// is its model + system prompt + tool set + a simple approval mode. Agents
// act on behalf of the invoking user (per-user isolation flows through
// ToolContext.userId in the executor), they have no standalone identity,
// team ownership, or encrypted secret of their own.
model Agent {
  id           String            @id @default(cuid())
  name         String
  description  String?
  avatarUrl    String?
  category     String?
  kind         String
  modelId      String
  instructions String
  skillIds     Json              @default("[]")
  approvalMode AgentApprovalMode @default(ask)
  maxToolCalls Int               @default(10)
  tokenBudget  Int?
  temperature  Float?
  userId       String?           @unique
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  runs              AgentRun[]
  llmModel          LlmModel           @relation(fields: [modelId], references: [id])
  chatConversations ChatConversation[]
  user              User?              @relation("AgentBackingUser", fields: [userId], references: [id], onDelete: SetNull)
  mcpServers        AgentMcpServer[]

  @@index([modelId])
}

// A named, admin-composed bundle of registry tools (a "skill"). Agents reference skills by id in
// their skillIds; at run time a skill resolves to whichever of its tools are currently registered.
// guidance is optional prose appended to the agent's system prompt so the model knows when to use it.
model Skill {
  id          String   @id @default(cuid())
  label       String
  description String?
  guidance    String?
  toolIds     Json     @default("[]")
  builtin     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// An external MCP server attached to an agent. Its tools are fetched at resolve time and merged
// into the agent's tool set. Admin-managed config; secrets are stored encrypted (AES-256-GCM) and
// never returned to clients. authKind is "none" | "bearer" | "oauth".
model AgentMcpServer {
  id              String          @id @default(cuid())
  agentId         String
  label           String
  url             String
  authKind        String          @default("none")
  bearerToken     Bytes?
  oauthScope      String?
  oauthClientInfo Bytes?
  oauthDiscovery  Json?
  toolAllowlist   Json            @default("[]")
  toolPrefix      String
  enabled         Boolean         @default(true)
  lastError       String?
  lastConnectedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  agent           Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  oauthTokens     McpOAuthToken[]
  oauthFlows      McpOAuthFlow[]

  @@index([agentId])
}

// Per-user OAuth tokens for an attached MCP server. Each invoking user authorizes once; tokens are
// stored encrypted and refreshed by the SDK when expired.
model McpOAuthToken {
  id           String         @id @default(cuid())
  mcpServerId  String
  userId       String
  accessToken  Bytes
  refreshToken Bytes?
  tokenType    String?
  scope        String?
  expiresAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  mcpServer    AgentMcpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mcpServerId, userId])
  @@index([userId])
}

// Short-lived in-flight OAuth state. id is the OAuth `state` value so the callback can correlate the
// redirect back to the user, server, and PKCE verifier.
model McpOAuthFlow {
  id           String         @id
  mcpServerId  String
  userId       String
  codeVerifier Bytes
  redirectTo   String
  expiresAt    DateTime
  createdAt    DateTime       @default(now())
  mcpServer    AgentMcpServer @relation(fields: [mcpServerId], references: [id], onDelete: Cascade)
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AgentRun {
  id             String      @id @default(cuid())
  agentId        String
  userId         String?
  trigger        String?
  taskId         String?
  conversationId String?
  status         AgentStatus
  input          Json
  output         Json?
  error          String?
  tokensInput    Int?
  tokensOutput   Int?
  costUsd        Decimal?    @db.Decimal(10, 6)
  containsWrites Boolean     @default(false)
  startedAt      DateTime    @default(now())
  finishedAt     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  agent          Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  task           Task?       @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([status])
  @@index([userId])
  @@index([taskId])
  @@index([conversationId])
}
