POSTGRES_PORT=5435
API_PORT=4000
WEB_PORT=3010

DATABASE_URL=postgresql://platform:platform@localhost:5435/platform?schema=public
NODE_ENV=development
WEB_ORIGIN=http://localhost:3010

# GitHub OAuth (create an OAuth app at https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ORG=your-org-slug
AUTH_CALLBACK_URL=http://localhost:3010/auth/github/callback

# Shared secret for the GitHub push webhook (mounted at
# /integrations/github/webhook). Must match the secret configured on each
# repo's webhook settings page. Leave blank to disable the endpoint — it
# returns 503 until this is set. Generate with e.g. `openssl rand -hex 32`.
GITHUB_WEBHOOK_SECRET=

SESSION_SECRET=replace-me-with-32-plus-random-bytes
SESSION_COOKIE_NAME=mep_sid

# On first login, this email (matched against the GitHub primary email) is auto-promoted to admin
BOOTSTRAP_ADMIN_EMAIL=

# Scaffolder secrets. Any env var prefixed with SCAFFOLDER_SECRET_ is exposed
# to actions via ctx.secrets.read("<NAME without prefix>"). Required for
# publish:github (the github-service template). Generate a fine-scoped PAT
# with repo creation/push permissions on the target org.
SCAFFOLDER_SECRET_GITHUB_TOKEN=

# Signing key for approval JWTs. Falls back to SESSION_SECRET in dev; set
# explicitly in production so rotating one doesn't invalidate the other.
SCAFFOLDER_APPROVAL_SECRET=

# Comma-separated capabilities the platform allows without an approval token.
# Defaults: humans get fs:write, fs:write:main, db:write; in-platform agents
# get fs:write only; external agents get nothing. Override per environment.
# SCAFFOLDER_HUMAN_CAPABILITIES=fs:write,fs:write:main,db:write
# SCAFFOLDER_AGENT_CAPABILITIES=fs:write
# SCAFFOLDER_EXTERNAL_AGENT_CAPABILITIES=

# Master key used to encrypt sensitive Integration.config fields (e.g. the
# Plane API token, webhook secret). 32 bytes hex. Generate with
# `openssl rand -hex 32`. Rotating this invalidates every stored integration
# secret — re-enter tokens in the Integrations UI after rotation.
INTEGRATION_SECRET_KEY=

# ngrok auth token for the dev tunnel started by `yarn dev`. The tunnel
# exposes the backend (API_PORT) at a public https URL so external services
# (Plane webhooks, GitHub webhooks) can reach this machine. Get a free
# token at https://dashboard.ngrok.com/get-started/your-authtoken.
# Leave blank to disable the tunnel — `yarn dev` will skip it with a
# friendly message and still start the app + backend.
NGROK_AUTHTOKEN=

# -----------------------------------------------------------------------------
# LLM provider API keys.
#
# Each key here is referenced by an LlmProvider row's `apiKeyEnvVar` column.
# An agent pointed at the matching provider will fail-fast at run time with a
# clear "Missing env var X required by provider 'slug'" error if the key is
# unset. Local providers (e.g. Ollama) do not need a key.
#
# Add the keys for whichever providers you actually use; leave the rest blank.
# -----------------------------------------------------------------------------

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Override the local Ollama base URL if you run it on a non-default host/port.
# The seed registers Ollama at http://localhost:11434/v1; if you change this,
# also update the LlmProvider.baseUrl row (Prisma Studio is the easiest path).
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Daily token cap for the Catalog Enricher cron. Defaults to 500_000.
# CATALOG_ENRICHER_DAILY_TOKEN_CAP=500000

# -----------------------------------------------------------------------------
# Platform Assistant (chatbot at /chat and the homepage widget)
# -----------------------------------------------------------------------------
# Override which seeded LlmModel the Platform Assistant uses. Default is the
# local Qwen 2.5 7B running on Ollama. Set to llmmodel_claude_sonnet_4_6 to
# swap to Claude Sonnet 4.6 (requires ANTHROPIC_API_KEY).
# CHAT_LLM_MODEL_ID=llmmodel_qwen25_7b_local

# When "false", the seeded Platform Assistant is registered with read tools
# only — no team_request_prepare / team_request_submit. Use during early
# rollout if local-model write quality is poor. Default: writes enabled.
# CHAT_WRITE_TOOLS_ENABLED=true

# Per-user daily turn cap for the chatbot. Soft warn at 80%; hard 429 at 100%.
# CHAT_DAILY_TURN_CAP=200
